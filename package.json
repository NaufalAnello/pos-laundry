{
  "name": "pos-laundry",
  "version": "1.0.0",
  "description": "Sistem POS Laundry berbasis web",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:fresh": "knex migrate:rollback --all && knex migrate:latest",
    "seed": "knex seed:run",
    "setup": "knex migrate:latest && knex seed:run",
    "check-db": "node scripts/check-db.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "connect-session-knex": "^4.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-session": "^1.18.0",
    "joi": "^17.12.2",
    "knex": "^3.1.0",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "pm2": "^5.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
